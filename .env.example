# Database
DATABASE_URL=postgresql://habit-agent:habit-agent@localhost:5434/habit-agent

# ── AI provider (text agent) ──────────────────────────────────────────────────
# Switch between OpenAI and Anthropic
AI_PROVIDER=openai              # openai | anthropic

# OpenAI models: gpt-4.1 | gpt-4.1-mini | gpt-4.1-nano
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini

# Anthropic models: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=your_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── STT provider (speech-to-text) ─────────────────────────────────────────────
# whisper  → OpenAI Whisper API   ~$0.006/min   ~800ms   reliable
# groq     → Groq Whisper         ~$0.00067/min ~150ms   9x cheaper, 5x faster
# elevenlabs → ElevenLabs Scribe  ~$0.0067/min  ~400ms   best quality
STT_PROVIDER=whisper            # whisper | groq | elevenlabs

WHISPER_MODEL=whisper-1         # only used when STT_PROVIDER=whisper

# GROQ_API_KEY=your_groq_key_here  # only needed when STT_PROVIDER=groq

# ── TTS provider (text-to-speech) ─────────────────────────────────────────────
# Always ElevenLabs — eleven_flash_v2_5 (lowest latency)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
# Voice IDs: Rachel=21m00Tcm4TlvDq8ikWAM  George=JBFqnCBsd6RMkjVDRZzb
# Browse more: elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=<same value as JWT_SECRET in AuthKit .env>
JWT_ALGORITHM=HS256

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
RATE_LIMIT_PER_MINUTE=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development: leave as default
# Production: set to your Vercel frontend URL
ALLOWED_ORIGINS=["http://localhost:3000"]
# ALLOWED_ORIGINS=["https://your-app.vercel.app"]
